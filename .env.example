# FluentFlow local development environment template.
# Copy this file to .env and fill only the services you use.
# Do not commit .env or real credentials.

# Local backend
# PORT=8000
# FLUENTFLOW_DATA_DIR=
# FLUENTFLOW_AUTH_MODE=accounts
# FLUENTFLOW_ALLOW_SIGNUPS=1

# Optional access token mode for local Agent/MCP testing.
# FLUENTFLOW_ACCESS_TOKEN=replace-with-local-dev-token

# AI note generation
# AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-reasoner
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.4-mini
# DASHSCOPE_API_KEY=
# Legacy alias for DASHSCOPE_API_KEY:
# QWEN_API_KEY=
# QWEN_MODEL=

# Cloud transcription
# ELEVENLABS_API_KEY=

# Legacy Azure transcription route
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_ENDPOINT=
# AZURE_BLOB_CONTAINER_SAS_URL=

# Feishu / Lark OpenAPI export
# LARK_APP_ID=
# LARK_APP_SECRET=
# LARK_OPEN_BASE_URL=https://open.feishu.cn
# FEISHU_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/account/feishu/oauth/callback
# FLUENTFLOW_FEISHU_OAUTH_SCOPES=offline_access

# Local lark-cli export
# FLUENTFLOW_LARK_CLI_BIN=
# FLUENTFLOW_LARK_CLI_WIKI_SPACE=

# Agent / MCP client defaults
# FLUENTFLOW_API_BASE=http://127.0.0.1:8000
# FLUENTFLOW_CLIENT_ID=local-client
