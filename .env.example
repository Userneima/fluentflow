# FluentFlow 本地环境变量模板
# 用法：cp .env.example .env，然后取消注释、填入你要用的服务的 key。
# 每个键都是可选的——按你要用的功能填。.env 含密钥，切勿提交。
#
# ✅ 最小可跑：只填一个 AI key（如 DEEPSEEK_API_KEY）即可上传本地音视频出笔记。
#    本地转录无需 key（但需 FFmpeg）；云端转录、飞书导出等按需再加对应 key。

# ── AI 笔记（至少配一个，否则只有转写没笔记）───────────────────────────
# AI_PROVIDER=deepseek                 # deepseek | openai | qwen
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-reasoner
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.4-mini
# DASHSCOPE_API_KEY=                   # 通义千问；也用于“笔记自动配图”的视觉模型
# QWEN_API_KEY=                        # DASHSCOPE_API_KEY 的旧别名
# QWEN_MODEL=

# ── 转录 ──────────────────────────────────────────────────────────
# 本地转录：无需 key（faster-whisper 首次运行自动下载模型），但需 FFmpeg。
# 云端转录（要用云端才填）：
# ELEVENLABS_API_KEY=

# ── 导出飞书 / Lark（要用飞书导出才填）──────────────────────────────
# LARK_APP_ID=
# LARK_APP_SECRET=
# LARK_OPEN_BASE_URL=https://open.feishu.cn                                      # 国内飞书填这个；Lark 国际版留空（默认 open.larksuite.com）
# FEISHU_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/account/feishu/oauth/callback  # 连个人飞书账号用；需在飞书开发者后台登记同一地址
# FLUENTFLOW_FEISHU_OAUTH_SCOPES=offline_access
# 本机 lark-cli 导出路线（可选）：
# FLUENTFLOW_LARK_CLI_BIN=
# FLUENTFLOW_LARK_CLI_WIKI_SPACE=

# ── Google 登录（可选）────────────────────────────────────────────
# 默认只请求 openid email profile；在 Google Cloud 登记同一 redirect URI。
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback
# FLUENTFLOW_GOOGLE_OAUTH_SCOPES=openid email profile

# ── 后端 / 账号（都可选，有合理默认）──────────────────────────────────
# PORT=8000
# FLUENTFLOW_DATA_DIR=                 # 默认 macOS: ~/Library/Application Support/FluentFlow
# FLUENTFLOW_AUTH_MODE=accounts
# FLUENTFLOW_ALLOW_SIGNUPS=1
# 媒体准入防线默认开启：空文件、无法读取的容器、无音轨、首段音频解码和数字静音。
# 遇到误判时可临时关闭总开关或单条开关，重启后端后生效。
# FLUENTFLOW_MEDIA_PREFLIGHT_ENABLED=1
# FLUENTFLOW_MEDIA_GUARD_EMPTY_FILE_ENABLED=1
# FLUENTFLOW_MEDIA_GUARD_CONTAINER_ENABLED=1
# FLUENTFLOW_MEDIA_GUARD_EXTENSION_ENABLED=1
# FLUENTFLOW_MEDIA_GUARD_AUDIO_STREAM_ENABLED=1
# FLUENTFLOW_MEDIA_GUARD_AUDIO_DECODE_ENABLED=1
# FLUENTFLOW_MEDIA_GUARD_SILENCE_ENABLED=1

# ── 未来 OSS 分片直传（当前默认关闭，尚未替换本机上传）────────────────────
# FLUENTFLOW_OSS_DIRECT_UPLOAD_ENABLED=0
# FLUENTFLOW_OSS_REGION=cn-hongkong
# 浏览器分片签名走公网 Endpoint；ECS 服务端控制/下载走同地域内网 Endpoint。
# FLUENTFLOW_OSS_PUBLIC_ENDPOINT=oss-cn-hongkong.aliyuncs.com
# FLUENTFLOW_OSS_INTERNAL_ENDPOINT=oss-cn-hongkong-internal.aliyuncs.com
# FLUENTFLOW_OSS_ENDPOINT=oss-cn-hongkong.aliyuncs.com  # 旧配置兼容，等同于 PUBLIC_ENDPOINT
# FLUENTFLOW_OSS_BUCKET=
# FLUENTFLOW_OSS_SOURCE_PREFIX=uploads/source/
# FLUENTFLOW_OSS_MULTIPART_PART_SIZE_MB=32
# FLUENTFLOW_OSS_MAX_SOURCE_MB=4096
# FLUENTFLOW_OSS_PRESIGN_TTL_SECONDS=900
# FLUENTFLOW_OSS_UPLOAD_SESSION_TTL_SECONDS=43200
# FLUENTFLOW_OSS_MAX_OPEN_SESSIONS_PER_CLIENT=3
# FLUENTFLOW_OSS_ECS_RAM_ROLE=FluentFlowOssUploadRole

# ── 进阶 / 可选 ───────────────────────────────────────────────────
# 生成笔记前用模型校对转写稿（默认关；开了会多花一次 LLM 调用）
# FLUENTFLOW_TRANSCRIPT_CORRECTION_ENABLED=0
# 本地 Agent / MCP 测试用的访问令牌模式
# FLUENTFLOW_ACCESS_TOKEN=replace-with-local-dev-token
# Agent / MCP 客户端默认值
# FLUENTFLOW_API_BASE=http://127.0.0.1:8000
# FLUENTFLOW_CLIENT_ID=local-client
