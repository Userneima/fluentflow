# Copy this file to /etc/fluentflow/fluentflow.env on the server.
# Do not commit the real env file.

PORT=8000

# Public beta mode: users only see cloud transcription and task controls.
FLUENTFLOW_PUBLIC_MODE=1
FLUENTFLOW_ALLOWED_STT_PROVIDERS=elevenlabs_scribe
FLUENTFLOW_DEFAULT_STT_PROVIDER=elevenlabs_scribe

# Account mode: first registration creates the admin account.
FLUENTFLOW_AUTH_MODE=accounts
FLUENTFLOW_DATA_DIR=/var/lib/fluentflow
FLUENTFLOW_ACCOUNT_DB_PATH=/var/lib/fluentflow/fluentflow_accounts.sqlite
FLUENTFLOW_JOB_DB_PATH=/var/lib/fluentflow/fluentflow_jobs.sqlite
FLUENTFLOW_EVENT_DB_PATH=/var/lib/fluentflow/fluentflow_events.sqlite
FLUENTFLOW_SESSION_DAYS=30
# Set to 1 only if you intentionally allow more users to self-register.
# FLUENTFLOW_ALLOW_SIGNUPS=1

# Google login. Configure this OAuth client as a Web application in Google
# Cloud, and keep the redirect URI exactly aligned with the deployed domain.
# New Google accounts can create FluentFlow users only when signups are allowed
# or when bootstrapping the first admin account.
# GOOGLE_OAUTH_CLIENT_ID=replace-with-google-oauth-client-id
# GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-oauth-client-secret
# GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.example/auth/google/callback
# FLUENTFLOW_GOOGLE_OAUTH_SCOPES=openid email profile

# Optional closed-beta access code. Leave it commented for public demo mode.
# FLUENTFLOW_ACCESS_TOKEN=replace-with-a-beta-access-code

# Abuse quota limits for a small single-server public demo.
FLUENTFLOW_MAX_UPLOAD_MB=2048
FLUENTFLOW_MAX_QUEUE_FILES=5
FLUENTFLOW_MAX_ACTIVE_JOBS_PER_CLIENT=2
FLUENTFLOW_MAX_ACTIVE_JOBS_GLOBAL=6
FLUENTFLOW_DAILY_JOB_LIMIT_PER_CLIENT=10
FLUENTFLOW_DAILY_JOB_LIMIT_GLOBAL=80
FLUENTFLOW_DAILY_UPLOAD_MB_PER_CLIENT=4096
FLUENTFLOW_DAILY_UPLOAD_MB_GLOBAL=32768
FLUENTFLOW_SUBMISSION_RATE_LIMIT_PER_IP=12
FLUENTFLOW_SUBMISSION_RATE_LIMIT_WINDOW_SECONDS=60
FLUENTFLOW_MAX_MEDIA_DURATION_SECONDS=14400
FLUENTFLOW_HISTORY_RETENTION_PER_CLIENT=20
FLUENTFLOW_ARTIFACT_RETENTION_DAYS=30
FLUENTFLOW_QUEUE_PROCESS_TIMEOUT_SECONDS=86400
FLUENTFLOW_STALE_JOB_SECONDS=90000

# Media admission guards. Keep every guard enabled in production. If one guard
# misclassifies normal media, disable only that guard, restart the service, and
# retain the rejection diagnostics for follow-up.
FLUENTFLOW_MEDIA_PREFLIGHT_ENABLED=1
FLUENTFLOW_MEDIA_GUARD_EMPTY_FILE_ENABLED=1
FLUENTFLOW_MEDIA_GUARD_CONTAINER_ENABLED=1
FLUENTFLOW_MEDIA_GUARD_EXTENSION_ENABLED=1
FLUENTFLOW_MEDIA_GUARD_AUDIO_STREAM_ENABLED=1
FLUENTFLOW_MEDIA_GUARD_AUDIO_DECODE_ENABLED=1
FLUENTFLOW_MEDIA_GUARD_SILENCE_ENABLED=1

# Optional video keyframe extraction for future note screenshots.
# Keep local_ffmpeg on a single ECS/Docker host. Use cloud_ffmpeg_worker only
# after deploying a separate worker that can read source video and return image artifacts.
FLUENTFLOW_KEYFRAME_EXTRACTION=1
FLUENTFLOW_KEYFRAME_PROVIDER=local_ffmpeg
# FLUENTFLOW_KEYFRAME_WORKER_URL=https://worker.example.com/keyframes

# ElevenLabs Scribe transcription.
ELEVENLABS_API_KEY=replace-with-elevenlabs-api-key

# Legacy Azure Batch transcription. Keep disabled unless you explicitly test the old route.
# AZURE_SPEECH_ENDPOINT=https://eastasia.api.cognitive.microsoft.com
# AZURE_SPEECH_KEY=replace-with-azure-speech-key
# AZURE_BLOB_CONTAINER_SAS_URL=https://youraccount.blob.core.windows.net/your-container?replace-with-container-sas

# Summary model. Bailian / DashScope powers the Qwen visual selector for
# video note screenshots. QWEN_API_KEY remains a legacy alias.
AI_PROVIDER=qwen
DASHSCOPE_API_KEY=replace-with-bailian-dashscope-api-key
# Optional, off by default. Transcript correction adds an extra LLM call before
# note generation and should be enabled only after quality/cost review.
# FLUENTFLOW_TRANSCRIPT_CORRECTION_ENABLED=0
# Optional text-only summary providers.
# DEEPSEEK_API_KEY=replace-with-deepseek-key
# OPENAI_API_KEY=replace-with-openai-key

# Feishu/Lark export. Optional if beta users only download local files.
LARK_APP_ID=replace-with-lark-app-id
LARK_APP_SECRET=replace-with-lark-app-secret
# LARK_OPEN_BASE_URL=https://open.feishu.cn
# FEISHU_OAUTH_REDIRECT_URI=https://your-domain.example/account/feishu/oauth/callback
# FLUENTFLOW_FEISHU_OAUTH_SCOPES=offline_access

# Optional explicit storage locations. Keep them on a disk with enough space.
# FLUENTFLOW_SOURCE_DIR=/var/lib/fluentflow/sources
# FLUENTFLOW_ARTIFACT_DIR=/var/lib/fluentflow/artifacts
# FLUENTFLOW_VIDEO_SOURCE_DIR=/var/lib/fluentflow/video-sources
# FLUENTFLOW_BACKUP_DIR=/var/backups/fluentflow
