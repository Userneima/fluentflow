{
  "version": "0.2.1",
  "scripts": {
    "dev:frontend": "node scripts/write_frontend_config.js && vite --config vite.config.mjs --host 127.0.0.1",
    "lint:frontend": "node scripts/lint_frontend.mjs",
    "test:frontend": "vitest run --config vitest.config.mjs",
    "change:check": "python3 scripts/check_change_control.py",
    "change:check:staged": "python3 scripts/check_change_control.py --staged",
    "mcp:check": "python3 scripts/check_mcp_server.py",
    "mcp:check:e2e": "python3 scripts/check_mcp_server.py --backend-e2e",
    "agent:mcp:eval": "python3 scripts/evaluate_agent_mcp.py",
    "note:quality": "python3 scripts/evaluate_note_quality.py",
    "note:sample": "python3 scripts/generate_note_sample.py",
    "note:modes": "python3 scripts/evaluate_note_modes.py",
    "stt:evaluate": "python3 scripts/evaluate_stt.py",
    "stt:compare": "python3 scripts/compare_stt_quality.py",
    "release:check": "python3 scripts/check_release_gate.py",
    "release:prepare": "python3 scripts/prepare_release.py",
    "build:frontend": "node scripts/write_frontend_config.js && vite build --config vite.config.mjs",
    "preview:frontend": "vite preview --config vite.config.mjs --host 127.0.0.1"
  },
  "dependencies": {
    "docx": "^9.7.1",
    "lucide-react": "^1.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "tailwindcss": "^3.4.18",
    "vite": "^8.0.16",
    "vitest": "^4.1.10"
  }
}
