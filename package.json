{
  "scripts": {
    "build:frontend": "node scripts/write_frontend_config.js && npm run build:css && npm run build:js",
    "build:css": "tailwindcss -c tailwind.config.cjs -i frontend/src/tailwind.css -o frontend/assets/tailwind.css --minify",
    "build:js": "babel frontend/src/app.jsx --presets @babel/preset-react --out-file frontend/assets/app.js --minified"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.3",
    "@babel/core": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "tailwindcss": "^3.4.18"
  }
}
